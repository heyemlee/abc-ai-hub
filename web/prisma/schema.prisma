generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── NextAuth models ──────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App models ───────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  image     String?
  role      Role     @default(USER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  accounts  Account[]
  sessions  Session[]
  reports   DailyReport[]
  customers Customer[]
  photos    CustomerPhoto[]
}

enum Role {
  USER
  ADMIN
}

model DailyReport {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  reportDate   DateTime @db.Date
  tasksToday   String
  planTomorrow String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, reportDate])
}

model Customer {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  name      String
  source    Source
  status    Status         @default(INTERESTED)
  phone     String?
  email     String?
  notes     String?
  photos    CustomerPhoto[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

enum Source {
  WALK_IN
  XIAOHONGSHU
  META
  INSTAGRAM
  REFERRAL
  OTHER
}

enum Status {
  INTERESTED
  FOLLOWING_UP
  QUOTED
  CLOSED_WON
  LOST
}

model CustomerPhoto {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staffId    String
  staff      User     @relation(fields: [staffId], references: [id])
  storageUrl String
  filename   String
  photoMonth String
  createdAt  DateTime @default(now())
}

model PhotoCleanupLog {
  id          String    @id @default(cuid())
  month       String    @unique
  remindedAt  DateTime?
  confirmedBy String?
  confirmedAt DateTime?
  deletedAt   DateTime?
}

model KBFile {
  id          String   @id @default(cuid())
  name        String
  type        String   // 'pdf' | 'image'
  category    String   // 'case-photos' | 'onboarding' | 'catalogs' | 'training' | 'policies'
  subCategory String?  // 'cases' | 'showroom'
  sizeBytes   Int
  storageUrl  String
  filename    String
  uploadedAt  DateTime @default(now())
}
