generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── NextAuth models ──────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App models ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  active        Boolean   @default(false)
  createdAt     DateTime  @default(now())

  accounts           Account[]
  sessions           Session[]
  reports            DailyReport[]
  customers          Customer[]
  photos             CustomerPhoto[]
  callScreenshots    CallScreenshot[]
  statusHistories    StatusHistory[]
  createdCases       Case[]              @relation("CaseCreator")
  caseMembers        CaseMember[]
  caseStatusChanges  CaseStatusHistory[]
  casePhotos         CasePhoto[]
  caseActivities     CaseActivity[]
}

enum Role {
  USER
  ADMIN
}

model DailyReport {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  reportDate   DateTime @db.Date
  tasksToday   String
  planTomorrow String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, reportDate])
}

model Customer {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  name           String
  source         Source
  status         Status          @default(ASKING_QUOTE)
  phone          String?
  email          String?
  notes          String?
  photos         CustomerPhoto[]
  statusHistory  StatusHistory[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum Source {
  WALK_IN
  XIAOHONGSHU
  INSTAGRAM_FACEBOOK
  REFERRAL
  EMAIL_MARKETING
  GOOGLE
  OTHER
}

enum Status {
  ASKING_QUOTE
  DRAWING
  IN_PROGRESS
  KEEP_CONTACT
  ON_HOLD
  ORDERED
  OTHERS
}

model StatusHistory {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  fromStatus Status?
  toStatus   Status
  note       String?
  createdAt  DateTime @default(now())
}

model CustomerPhoto {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staffId    String
  staff      User     @relation(fields: [staffId], references: [id])
  storageUrl String
  filename   String
  photoMonth String
  createdAt  DateTime @default(now())
}

model PhotoCleanupLog {
  id          String    @id @default(cuid())
  month       String    @unique
  remindedAt  DateTime?
  confirmedBy String?
  confirmedAt DateTime?
  deletedAt   DateTime?
}

model KBFile {
  id          String   @id @default(cuid())
  name        String
  type        String   // 'pdf' | 'image'
  category    String   // 'case-photos' | 'onboarding' | 'catalogs' | 'training' | 'policies'
  subCategory String?  // 'cases' | 'showroom'
  sizeBytes   Int
  storageUrl  String
  filename    String
  uploadedAt  DateTime @default(now())
}

model CallScreenshot {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  storageUrl String
  filename   String
  photoMonth String   // e.g. "2026-03"
  createdAt  DateTime @default(now())
}

// ── Case Management ──────────────────────────────────────

model Case {
  id          String     @id @default(cuid())
  title       String
  clientName  String
  clientPhone String?
  clientEmail String?
  createdById String
  createdBy   User       @relation("CaseCreator", fields: [createdById], references: [id])
  status      CaseStatus @default(ASKING_QUOTE)
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  members       CaseMember[]
  statusHistory CaseStatusHistory[]
  photos        CasePhoto[]
  activities    CaseActivity[]
}

enum CaseStatus {
  ASKING_QUOTE
  DRAWING
  IN_PROGRESS
  ON_HOLD
  ORDERED
  CANCELLED
}

model CaseMember {
  id     String         @id @default(cuid())
  caseId String
  case   Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId String
  user   User           @relation(fields: [userId], references: [id])
  role   CaseMemberRole @default(COLLABORATOR)
  addedAt DateTime      @default(now())

  @@unique([caseId, userId])
}

enum CaseMemberRole {
  OWNER
  COLLABORATOR
}

model CaseStatusHistory {
  id         String      @id @default(cuid())
  caseId     String
  case       Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  fromStatus CaseStatus?
  toStatus   CaseStatus
  note       String?
  createdAt  DateTime    @default(now())
}

model CasePhoto {
  id         String   @id @default(cuid())
  caseId     String
  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploadedBy String
  uploader   User     @relation(fields: [uploadedBy], references: [id])
  storageUrl String
  filename   String
  caption    String?
  createdAt  DateTime @default(now())
}

model CaseActivity {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // "note" | "status_change" | "photo_upload" | "member_added" | "member_removed"
  content   String?
  createdAt DateTime @default(now())
}
